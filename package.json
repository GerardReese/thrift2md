{
  "name": "@gerardreese/thrift2md",
  "version": "0.0.1",
  "description": "Thrift to Markdown converter",
  "main": "dist/index.js",
  "bin": "dist/bin/index.js",
  "scripts": {
    "clean": "rimraf coverage/ dist/ node_modules/",
    "build": "tsc",
    "lint": "tslint src/**/*",
    "test": "tsc && lab --coverage --coverage-path ./dist/main --sourcemaps ./dist/test/**/*.spec.js",
    "test:watch": "watch 'npm test' ./src",
    "conversion": "node dist/bin/thrift2md.js ./fixtures/thrift/tutorial.thrift ./fixtures/md",
    "coverage": "lab --coverage --sourcemaps -r console -o stdout -r html -o ./coverage/coverage.html ./dist/test/**/*.spec.js",
    "release:patch": "npm version patch && npm run release:publish",
    "release:minor": "npm version minor && npm run release:publish",
    "release:major": "npm version major && npm run release:publish",
    "release:publish": "npm publish && git push --follow-tags"
  },
  "keywords": [
    "thrift",
    "markdown"
  ],
  "author": "Nick Nance",
  "contributors": [
    "Microsoft Corporation"
  ],
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/gerardreese/thrift2md"
  },
  "devDependencies": {
    "@types/code": "^4.0.4",
    "@types/json2md": "^1.5.0",
    "@types/lab":"^11.1.4",
    "@types/node": "^18.16.19",
    "@types/node-int64":"^0.4.32",
    "@types/rimraf": "^2.0.2",
    "@types/thrift": "^0.10.7",
    "code": "^5.2.0",
    "diff": "^8.0.3",
    "eslint": "10.0.2",
    "handlebars": "^4.7.7",
    "js-yaml": "^3.2.7",
    "lab":"^18.0.2",
    "minimatch": "^3.1.5",
    "tslint": "^5.9.1",
    "typescript": "^5.6.3",
    "uglify-js": "^2.8.9",
    "watch": "^0.13.0",
    "tmp":"^0.2.5",
    "brace-expansion":"^5.0.4"
  },
  "dependencies": {
    "@creditkarma/thrift-parser": "^1.2.0",
    "json2md": "^1.6.1",
    "rimraf": "^2.6.2"
  }
}